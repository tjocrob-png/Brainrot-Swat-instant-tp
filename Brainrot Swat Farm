local function buildGameCards()
    for _, c in pairs(gameCards) do c:Destroy() end
    gameCards = {}
    local query = searchBox.Text:lower()
    local y = 106
    for _, g in ipairs(gamesList) do
        if query == "" or g.name:lower():find(query, 1, true) then
            local card = Instance.new("Frame", gamesListPage)
            card.Size = UDim2.new(0.92, 0, 0, 44)
            card.Position = UDim2.new(0.04, 0, 0, y)
            card.BackgroundColor3 = Color3.fromRGB(68, 50, 125)
            card.ZIndex = 4
            Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)
            local nameLbl = Instance.new("TextLabel", card)
            nameLbl.Size = UDim2.new(0.65, 0, 1, 0)
            nameLbl.Position = UDim2.new(0, 14, 0, 0)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Text = g.name
            nameLbl.TextColor3 = COLOR_WHITE
            nameLbl.Font = Enum.Font.GothamMedium
            nameLbl.TextSize = 13
            nameLbl.TextXAlignment = Enum.TextXAlignment.Left
            nameLbl.ZIndex = 5
            local barHeights = { 8, 13, 18 }
            local barColor = g.supported and Color3.fromRGB(80, 210, 80) or Color3.fromRGB(210, 60, 60)
            for b = 1, 3 do
                local bar = Instance.new("Frame", card)
                bar.Size = UDim2.new(0, 5, 0, barHeights[b])
                bar.Position = UDim2.new(1, -44 + (b - 1) * 9, 0.5, -barHeights[b] / 2)
                bar.BackgroundColor3 = barColor
                bar.ZIndex = 5
                Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 2)
            end
            local statusLbl = Instance.new("TextLabel", card)
            statusLbl.Size = UDim2.new(0, 70, 1, 0)
            statusLbl.Position = UDim2.new(1, -120, 0, 0)
            statusLbl.BackgroundTransparency = 1
            statusLbl.Text = g.supported and "✔ Works" or "✘ No support"
            statusLbl.TextColor3 = g.supported and Color3.fromRGB(100, 230, 100) or Color3.fromRGB(230, 80, 80)
            statusLbl.Font = Enum.Font.Gotham
            statusLbl.TextSize = 11
            statusLbl.TextXAlignment = Enum.TextXAlignment.Right
            statusLbl.ZIndex = 5

            if g.placeId then
                local teleportBtn = Instance.new("TextButton", card)
                teleportBtn.Size = UDim2.new(1, 0, 1, 0)
                teleportBtn.BackgroundTransparency = 1
                teleportBtn.Text = ""
                teleportBtn.ZIndex = 6
                teleportBtn.MouseButton1Click:Connect(function()
                    if not errorLbl then return end
                    errorLbl.Text = "Attempting teleport to " .. g.name .. "... (this can sometimes fail to load)"
                    errorLbl.TextColor3 = COLOR_DIM
                    errorLbl.Visible = true
                    local ok, err = pcall(function()
                        TeleportService:Teleport(g.placeId, player)
                    end)
                    if not ok then
                        errorLbl.Text = "Teleport FAILED: " .. tostring(err)
                        errorLbl.TextColor3 = Color3.fromRGB(230, 90, 90)
                    end
                end)
            end

            table.insert(gameCards, card)
            y = y + 52
        end
    end
end
