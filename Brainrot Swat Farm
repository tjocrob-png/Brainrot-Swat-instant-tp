closeBtn.Text = "X"; closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50); closeBtn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 15)

closeBtn.MouseButton1Click:Connect(function() 
    mainFrame.Visible = false 
    openBtn.Visible = true
end)

openBtn.MouseButton1Click:Connect(function() 
    mainFrame.Visible = true 
    openBtn.Visible = false 
end)

local function createButton(text, parent, pos)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.9, 0, 0, 40); btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(75, 55, 120); btn.Text = text; btn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
    return btn
end

local farmToggle = createButton("Farm: OFF", mainFrame, UDim2.new(0.05, 0, 0.1, 0))
local placeToggle = createButton("Auto Equip: OFF", mainFrame, UDim2.new(0.05, 0, 0.2, 0))
local rebirthToggle = createButton("Auto Rebirth: OFF", mainFrame, UDim2.new(0.05, 0, 0.3, 0))
local upgradeToggle = createButton("Auto Upgrade Speed: OFF", mainFrame, UDim2.new(0.05, 0, 0.4, 0))
local hideToggle = createButton("Hide Other UI: OFF", mainFrame, UDim2.new(0.05, 0, 0.5, 0))
local consoleBtn = createButton("Open Console", mainFrame, UDim2.new(0.05, 0, 0.6, 0))

-- 2. LOGIC
farmToggle.MouseButton1Click:Connect(function() active = not active; farmToggle.Text = "Farm: " .. (active and "ON" or "OFF") end)
placeToggle.MouseButton1Click:Connect(function() autoPlace = not autoPlace; placeToggle.Text = "Auto Equip: " .. (autoPlace and "ON" or "OFF") end)
rebirthToggle.MouseButton1Click:Connect(function() autoRebirth = not autoRebirth; rebirthToggle.Text = "Auto Rebirth: " .. (autoRebirth and "ON" or "OFF") end)
upgradeToggle.MouseButton1Click:Connect(function() autoUpgrade = not autoUpgrade; upgradeToggle.Text = "Auto Upgrade Speed: " .. (autoUpgrade and "ON" or "OFF") end)

consoleBtn.MouseButton1Click:Connect(function()
    pcall(function() game:GetService("StarterGui"):SetCore("DevConsoleVisible", true) end)
end)

hideToggle.MouseButton1Click:Connect(function()
    hideOtherUI = not hideOtherUI
    hideToggle.Text = "Hide Other UI: " .. (hideOtherUI and "ON" or "OFF")
    for _, gui in pairs(PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui ~= screenGui then
            gui.Enabled = not hideOtherUI
        end
    end
end)

-- 3. LOOPS
task.spawn(function()
    while task.wait(0.5) do
        if active then
            local PurchaseEvent = ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("PurchaseUpgrade")
            if PurchaseEvent and grabLimit < 6 then PurchaseEvent:FireServer("CarryCapacity", 1); grabLimit = math.min(grabLimit + 1, 6) end
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local itemSpawns = workspace:FindFirstChild("ItemSpawns")
                local target = (itemSpawns and itemSpawns:FindFirstChild("9") and itemSpawns["9"]:FindFirstChild("SpawnedItem")) and itemSpawns["9"]
                             or (itemSpawns and itemSpawns:FindFirstChild("8") and itemSpawns["8"]:FindFirstChild("SpawnedItem") and itemSpawns["8"])
                local prompt = target and target:FindFirstChild("SpawnedItem"):FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then
                    hrp.CFrame = target:FindFirstChild("SpawnedItem"):GetPivot()
                    task.wait(0.2)
                    for i = 1, grabLimit do if prompt and prompt.Parent then fireproximityprompt(prompt) end task.wait(0.05) end
                    if workspace:FindFirstChild("Zones") and workspace.Zones:FindFirstChild("BikeSpawn") then hrp.CFrame = workspace.Zones.BikeSpawn:GetPivot() end
                end
            end
        end
    end
end)

task.spawn(function()
    while task.wait(2) do
