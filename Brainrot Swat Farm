screenGui.Name = "HaiperEXE_Script"
screenGui.ResetOnSpawn = false
screenGui.IgnoreGuiInset = true
screenGui.DisplayOrder = 999 

local mainFrame = Instance.new("Frame", screenGui)
mainFrame.Size = UDim2.new(0, 340, 0, 450); mainFrame.Position = UDim2.new(0.5, -170, 0.5, -225)
mainFrame.BackgroundColor3 = Color3.fromRGB(58, 39, 98); mainFrame.Active = true; mainFrame.Draggable = true
Instance.new("UICorner", mainFrame).CornerRadius = UDim.new(0, 12)

-- Mini Open Button (Moved to Y: 0.5, X: 0.05 to avoid sidebar conflict)
local openBtn = Instance.new("TextButton", screenGui)
openBtn.Size = UDim2.new(0, 100, 0, 40); openBtn.Position = UDim2.new(0, 10, 0.4, 0)
openBtn.BackgroundColor3 = Color3.fromRGB(58, 39, 98); openBtn.Text = "Open Menu"; openBtn.TextColor3 = Color3.new(1,1,1)
