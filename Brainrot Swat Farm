local function getExecutor()
    if identifyexecutor then
        local ok, name = pcall(identifyexecutor)
        if ok and name and name ~= "" then return name end
    end
    if syn and syn.request then return "Synapse X" end
    if KRNL_LOADED then return "KRNL" end
    if fluxus then return "Fluxus" end
    if delta then return "Delta" end
    if getgenv then
        local env = getgenv()
        if env.ARCEUS_X or env.ARCEUSX then return "Arceus X" end
        if env.hydrogen then return "Hydrogen" end
        if env.Nezur then return "Nezur" end
        if env.Vega then return "Vega" end
        if env.Nihon then return "Nihon" end
        if env.AWP then return "AWP" end
        if env.Coco_Z then return "Coco Z" end
        if env.ScriptBlox then return "ScriptBlox" end
        if env.Solara then return "Solara" end
        if env.Celery then return "Celery" end
        if env.Seliware then return "Seliware" end
        if env.Cryptic then return "Cryptic" end
        if env.Zorara then return "Zorara" end
        if env.Matcha then return "Matcha" end
        if env.Potassium then return "Potassium" end
        if env.Sirhurt then return "Sir Hurt" end
        if env.OxygenU then return "Oxygen U" end
        if env.ScriptName == "Electron" then return "Electron" end
        if env.VOLCANO then return "Volcano" end
        if env.AWP_LOADED then return "AWP" end
    end
    if is_sirhurt_closure then return "Sir Hurt" end
    if pebc_execute then return "Electron" end
    if COREGUI then return "Coco Z" end
    return "Unknown"
end
